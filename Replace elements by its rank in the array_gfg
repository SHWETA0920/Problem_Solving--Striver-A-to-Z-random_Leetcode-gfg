class Solution {
public:
    vector<int> replaceWithRank(vector<int> &arr, int N) {
        vector<int> temp = arr;
        sort(temp.begin(), temp.end());

        unordered_map<int, int> m;

        for (int i = 0; i < N; i++) {
            auto it = m.find(temp[i]);

            if (it == m.end()) {                
                m[temp[i]] = m.size() + 1;
            }
        }

        for (int i = 0; i < N; i++) {
            arr[i] = m[arr[i]];
        }

        return arr;
    }
};
